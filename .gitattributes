# Keep text files stable across platforms.
* text=auto eol=lf

# Windows shell scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# POSIX scripts and source files should keep LF.
*.sh text eol=lf
*.py text eol=lf

# Firmware payloads are binary and must never be normalized.
*.bin binary
*.mbn binary
*.img binary
*.elf binary
*.fv binary
*.zip binary
*.tgz binary

# Store large but supported firmware blobs in Git LFS.
Fastboot/images/MODEM-FW.bin filter=lfs diff=lfs merge=lfs -text
Fastboot/images/NON-HLOS.bin filter=lfs diff=lfs merge=lfs -text
Fastboot/images/vm-persist.img filter=lfs diff=lfs merge=lfs -text
